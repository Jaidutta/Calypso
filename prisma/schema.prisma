// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // allows prisma to manage automatically

  eventType EventType[]

  @@map("users")
}

// A user has many eventTypes, and an eventType belongs to one user (One to Many)
model EventType {
  id                  Int      @id @default(autoincrement())
  hostId              Int
  title               String
  description         String?
  durationMinutes     Int
  isActive            Boolean  @default(true)
  locationType        String   @default("online")
  locationValue       String?
  bufferBeforeMinutes Int      @default(0)
  bufferAfterMinutes  Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // id of the User table is present as a hostId in my table
  host User @relation(fields: [hostId], references: [id], onDelete: Cascade) // Cascade: If the user is deleted, all its eventTypes will be deleted

  @@map("event_types")
}
